def find_value_coordinates_in_chunk(chunk, extracted_value):
    if chunk is None or extracted_value is None:
        return []

    metadata = getattr(chunk, "metadata", {})
    lines = metadata.get("lines", [])

    print("----- DEBUG COORDINATE MATCHING -----")
    print("Extracted value:", extracted_value)
    print("Chunk metadata keys:", metadata.keys())
    print("Lines type:", type(lines))

    if not isinstance(lines, list) or not lines:
        print("No valid lines found in metadata.")
        return []

    print("Total lines in chunk:", len(lines))

    target_norm = normalize_for_match(extracted_value)

    if not target_norm:
        print("Target normalized value is empty.")
        return []

    matched_coordinates = []

    # 1) Strong exact / substring line matching
    for idx, line in enumerate(lines):
        line_text = str(line.get("text", ""))
        line_norm = normalize_for_match(line_text)

        print(f"Line {idx+1}: {line_text}")
        print("Normalized line:", line_norm)
        print("Target:", target_norm)

        if not line_norm:
            continue

        if target_norm == line_norm or target_norm in line_norm or line_norm in target_norm:
            print("Matched using exact/substring line logic.")
            matched_coordinates.extend(build_coordinate_objects_from_lines([line]))
            continue

        score = SequenceMatcher(None, target_norm, line_norm).ratio()
        print("Line score:", score)

        if score >= 0.85:
            print("Matched using fuzzy single-line logic.")
            matched_coordinates.extend(build_coordinate_objects_from_lines([line]))

    # 2) Consecutive multi-line matching
    max_window = min(5, len(lines))
    for window_size in range(2, max_window + 1):
        for i in range(len(lines) - window_size + 1):
            line_group = lines[i:i + window_size]
            combined_text = " ".join(str(line.get("text", "")) for line in line_group)
            combined_norm = normalize_for_match(combined_text)

            if not combined_norm:
                continue

            if target_norm == combined_norm or target_norm in combined_norm or combined_norm in target_norm:
                print(f"Matched using exact/substring multi-line logic: lines {i+1} to {i+window_size}")
                matched_coordinates.extend(build_coordinate_objects_from_lines(line_group))
                continue

            score = SequenceMatcher(None, target_norm, combined_norm).ratio()
            print(f"Multi-line score ({i+1}-{i+window_size}):", score)

            if score >= 0.82:
                print(f"Matched using fuzzy multi-line logic: lines {i+1} to {i+window_size}")
                matched_coordinates.extend(build_coordinate_objects_from_lines(line_group))

    matched_coordinates = deduplicate_coordinates(matched_coordinates)
    print("Final matched coordinates:", matched_coordinates)
    return matched_coordinates

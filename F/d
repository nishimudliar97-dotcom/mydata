import json
import os
import re
import unicodedata
from difflib import SequenceMatcher

import fitz  # PyMuPDF


def normalize_text(text):
    if type(text) != str:
        return text

    text = unicodedata.normalize("NFKC", text)

    replacements = {
        "\u202f": " ",
        "\u00a0": " ",
        "\u2011": "-",
        "\u2013": "-",
        "\u2014": "-",
    }

    for k, v in replacements.items():
        text = text.replace(k, v)

    text = re.sub(r"\s+", " ", text)
    return text.strip()


def normalize_for_match(text):
    if text is None:
        return ""

    text = normalize_text(text)
    text = text.lower()
    text = re.sub(r"[^a-z0-9]+", "", text)
    return text.strip()


def parse_llm_output(raw_output):
    default_output = {"value": None, "chunk_id": None}

    if raw_output is None:
        return default_output

    if isinstance(raw_output, dict):
        data = raw_output
    else:
        raw_output = str(raw_output).strip()

        if raw_output.startswith("```json"):
            raw_output = raw_output[len("```json"):].strip()
        elif raw_output.startswith("```"):
            raw_output = raw_output[len("```"):].strip()

        if raw_output.endswith("```"):
            raw_output = raw_output[:-3].strip()

        try:
            data = json.loads(raw_output)
        except Exception:
            try:
                start = raw_output.find("{")
                end = raw_output.rfind("}")
                if start != -1 and end != -1:
                    data = json.loads(raw_output[start:end + 1])
                else:
                    return default_output
            except Exception:
                return default_output

    normalized_keys = {}
    for k, v in data.items():
        key = str(k).lower().replace(" ", "").replace("_", "")
        normalized_keys[key] = v

    value = normalized_keys.get("value")
    chunk_id = normalized_keys.get("chunkid")

    if isinstance(value, str) and value.strip().lower() in {"not_found", "null", "none"}:
        value = None

    if isinstance(chunk_id, str) and chunk_id.strip().lower() in {"not_found", "null", "none"}:
        chunk_id = None

    return {
        "value": value,
        "chunk_id": chunk_id,
    }


def find_chunk_by_id(retrieved_chunks, chunk_id):
    if not chunk_id:
        return None

    for chunk in retrieved_chunks:
        metadata = getattr(chunk, "metadata", {})
        if metadata.get("chunk_id") == chunk_id:
            return chunk

    return None


def merge_bboxes(bboxes):
    valid_bboxes = []

    for bbox in bboxes:
        if isinstance(bbox, (list, tuple)) and len(bbox) == 4:
            valid_bboxes.append([float(x) for x in bbox])

    if not valid_bboxes:
        return None

    return [
        min(bbox[0] for bbox in valid_bboxes),
        min(bbox[1] for bbox in valid_bboxes),
        max(bbox[2] for bbox in valid_bboxes),
        max(bbox[3] for bbox in valid_bboxes),
    ]


def score_match(target_norm, candidate_norm):
    if not target_norm or not candidate_norm:
        return 0.0

    if target_norm == candidate_norm:
        return 1.0

    if target_norm in candidate_norm or candidate_norm in target_norm:
        return 0.98

    return SequenceMatcher(None, target_norm, candidate_norm).ratio()


def deduplicate_coordinates(coordinates):
    unique_coordinates = []
    seen = set()

    for coord in coordinates:
        page = coord.get("Page")
        bbox = coord.get("B_Box")

        if not isinstance(bbox, (list, tuple)) or len(bbox) != 4:
            continue

        bbox = [float(x) for x in bbox]

        key = (
            page,
            round(bbox[0], 4),
            round(bbox[1], 4),
            round(bbox[2], 4),
            round(bbox[3], 4),
        )

        if key not in seen:
            seen.add(key)
            unique_coordinates.append(
                {
                    "Page": page,
                    "B_Box": bbox
                }
            )

    unique_coordinates.sort(key=lambda x: x["Page"])
    return unique_coordinates


def rect_to_list(rect):
    return [float(rect.x0), float(rect.y0), float(rect.x1), float(rect.y1)]


def rect_distance(rect_bbox, line_bbox):
    if not line_bbox:
        return 10**9

    rx0, ry0, rx1, ry1 = rect_bbox
    lx0, ly0, lx1, ly1 = line_bbox

    rect_cx = (rx0 + rx1) / 2
    rect_cy = (ry0 + ry1) / 2
    line_cx = (lx0 + lx1) / 2
    line_cy = (ly0 + ly1) / 2

    return ((rect_cx - line_cx) ** 2 + (rect_cy - line_cy) ** 2) ** 0.5


def get_candidate_line_matches(lines, extracted_value):
    target_norm = normalize_for_match(extracted_value)
    if not target_norm:
        return []

    matched_lines = []

    # Single line matches
    for line in lines:
        line_text = str(line.get("text", ""))
        line_norm = normalize_for_match(line_text)

        if not line_norm:
            continue

        if target_norm == line_norm or target_norm in line_norm or line_norm in target_norm:
            matched_lines.append([line])
            continue

        score = score_match(target_norm, line_norm)
        if score >= 0.85:
            matched_lines.append([line])

    # Multi-line matches
    max_window = min(5, len(lines))
    for window_size in range(2, max_window + 1):
        for i in range(len(lines) - window_size + 1):
            line_group = lines[i:i + window_size]
            combined_text = " ".join(str(line.get("text", "")) for line in line_group)
            combined_norm = normalize_for_match(combined_text)

            if not combined_norm:
                continue

            if target_norm == combined_norm or target_norm in combined_norm or combined_norm in target_norm:
                matched_lines.append(line_group)
                continue

            score = score_match(target_norm, combined_norm)
            if score >= 0.82:
                matched_lines.append(line_group)

    return matched_lines


def build_line_level_fallback_coordinates(matched_line_groups):
    coordinates = []

    for line_group in matched_line_groups:
        page_to_bboxes = {}

        for line in line_group:
            page = line.get("page")
            bbox = line.get("bbox")

            if page is None or bbox is None:
                continue

            if not isinstance(bbox, (list, tuple)) or len(bbox) != 4:
                continue

            bbox = [float(x) for x in bbox]
            page_to_bboxes.setdefault(page, []).append(bbox)

        for page, bboxes in page_to_bboxes.items():
            merged_bbox = merge_bboxes(bboxes)
            if merged_bbox is not None:
                coordinates.append(
                    {
                        "Page": page,
                        "B_Box": merged_bbox
                    }
                )

    return deduplicate_coordinates(coordinates)


def search_exact_value_in_pdf(pdf_path, candidate_pages_with_bboxes, extracted_value):
    if not pdf_path or not os.path.exists(pdf_path):
        return []

    if not extracted_value or not isinstance(extracted_value, str):
        return []

    exact_coordinates = []

    try:
        doc = fitz.open(pdf_path)

        for page_number, nearby_line_bbox in candidate_pages_with_bboxes:
            if page_number < 1 or page_number > len(doc):
                continue

            page = doc[page_number - 1]
            rects = page.search_for(extracted_value)

            if not rects:
                continue

            rect_bbox_list = [rect_to_list(rect) for rect in rects]

            # If a nearby line bbox is known, sort results by closeness to that line
            if nearby_line_bbox is not None:
                rect_bbox_list.sort(key=lambda r: rect_distance(r, nearby_line_bbox))

            for rect_bbox in rect_bbox_list:
                exact_coordinates.append(
                    {
                        "Page": page_number,
                        "B_Box": rect_bbox
                    }
                )

        doc.close()
    except Exception as e:
        print(f"Error while doing exact PDF search: {e}")
        return []

    return deduplicate_coordinates(exact_coordinates)


def build_candidate_pages_with_bboxes(matched_line_groups):
    candidate_pages = []

    for line_group in matched_line_groups:
        page_to_bboxes = {}

        for line in line_group:
            page = line.get("page")
            bbox = line.get("bbox")

            if page is None or bbox is None:
                continue

            if not isinstance(bbox, (list, tuple)) or len(bbox) != 4:
                continue

            bbox = [float(x) for x in bbox]
            page_to_bboxes.setdefault(page, []).append(bbox)

        for page, bboxes in page_to_bboxes.items():
            merged_bbox = merge_bboxes(bboxes)
            candidate_pages.append((page, merged_bbox))

    # deduplicate page + bbox pairs
    seen = set()
    unique_candidate_pages = []

    for page, bbox in candidate_pages:
        if bbox is None:
            key = (page, None)
        else:
            key = (
                page,
                round(bbox[0], 4),
                round(bbox[1], 4),
                round(bbox[2], 4),
                round(bbox[3], 4),
            )

        if key not in seen:
            seen.add(key)
            unique_candidate_pages.append((page, bbox))

    return unique_candidate_pages


def find_value_coordinates_in_chunk(chunk, extracted_value, pdf_root_path):
    if chunk is None or extracted_value is None:
        return []

    metadata = getattr(chunk, "metadata", {})
    lines = metadata.get("lines", [])
    document_name = metadata.get("document")

    print("----- DEBUG EXACT VALUE COORDINATE MATCHING -----")
    print("Extracted value:", extracted_value)
    print("Document name:", document_name)

    if not isinstance(lines, list) or not lines:
        print("No valid lines found in metadata.")
        return []

    # Step 1: find likely matching lines/pages
    matched_line_groups = get_candidate_line_matches(lines, extracted_value)
    print("Matched line groups count:", len(matched_line_groups))

    if not matched_line_groups:
        return []

    # Step 2: build candidate pages from matched lines
    candidate_pages_with_bboxes = build_candidate_pages_with_bboxes(matched_line_groups)
    print("Candidate pages with bboxes:", candidate_pages_with_bboxes)

    # Step 3: exact value search inside actual PDF
    pdf_path = os.path.join(pdf_root_path, document_name) if document_name else None
    exact_coordinates = search_exact_value_in_pdf(pdf_path, candidate_pages_with_bboxes, extracted_value)
    print("Exact search coordinates:", exact_coordinates)

    if exact_coordinates:
        return exact_coordinates

    # Step 4: fallback to line-level bbox if exact text search fails
    fallback_coordinates = build_line_level_fallback_coordinates(matched_line_groups)
    print("Fallback line-level coordinates:", fallback_coordinates)
    return fallback_coordinates


def build_field_output(extracted_value, selected_chunk, coordinates):
    if selected_chunk is None:
        return {
            "Value": normalize_text(extracted_value) if extracted_value is not None else None,
            "Document Category": None,
            "Document ID": None,
            "Coordinates": []
        }

    metadata = getattr(selected_chunk, "metadata", {})

    return {
        "Value": normalize_text(extracted_value) if extracted_value is not None else None,
        "Document Category": metadata.get("category"),
        "Document ID": metadata.get("document"),
        "Coordinates": coordinates
    }
